oci_region           = "eu-madrid-1"
compartment_id       = "ocid1.compartment.oc1..example"
availability_domain  = "kIdk:EU-MADRID-1-AD-1"
subnet_id            = "ocid1.subnet.oc1.eu-madrid-1.example"
image_id             = "ocid1.image.oc1.eu-madrid-1.example"
instance_shape       = "VM.Standard.E4.Flex"
