limit_req_zone $binary_remote_addr zone=leoai_chat_limit:10m rate=10r/m;

upstream leoai_api_upstream {
    server 127.0.0.1:{{ leoai_api_port }};
    keepalive 32;
}

server {
    listen {{ leoai_public_http_port }};
    server_name {{ leoai_tls_domain | default('_', true) if leoai_tls_domain | length > 0 else '_' }};

    client_max_body_size 10m;
{% if leoai_tls_mode in ["self_signed", "letsencrypt"] %}
    return 301 https://$host$request_uri;
{% else %}

    location /chat {
        limit_req zone=leoai_chat_limit burst=20 nodelay;
        proxy_pass http://leoai_api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://leoai_api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
{% endif %}
}

{% if leoai_tls_mode in ["self_signed", "letsencrypt"] %}
server {
    listen {{ leoai_public_https_port }} ssl http2;
    server_name {{ leoai_tls_domain | default('_', true) if leoai_tls_domain | length > 0 else '_' }};

    ssl_certificate {{ leoai_tls_cert_path }};
    ssl_certificate_key {{ leoai_tls_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy no-referrer always;

    client_max_body_size 10m;

    location /chat {
        limit_req zone=leoai_chat_limit burst=20 nodelay;
        proxy_pass http://leoai_api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }

    location / {
        proxy_pass http://leoai_api_upstream;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
{% endif %}
